#!/bin/bash
    : ${RCSID:=$Id: gh-makerelease 1.1 2026-03-01 - $}
    : ${PROGRAM_TITLE:="Create a GitHub release with auto-detected project type"}
    : ${PROGRAM_SYNTAX:="[OPTIONS]"}

    . shlib-import cliboot

    option -n --no-pre-clean    "Reuse build cache"
    option -u --unsigned        "Build unsigned packages"
    option -l --local           "Build in local, no tag/push/release"
    option -f --force           "Replace existing release and tag if present"
    option -v --verbose         "Verbose logging"
    option -q --quiet           "Less output"
    option -h --help            "Show help"

    opt_force=
    opt_local=0

    # -b: Equivalent to --build=binary or --build=any,all
    # -us: --unsigned-source
    # -uc: --unsigned-changes
    dpkg_buildopts=( -b  )

function setopt() {
    case "$1" in
        -u|--unsigned)
            dpkg_buildopts+=( -us -uc );;
        -n|--no-pre-clean)
            dpkg_buildopts+=( -nc );;
        -l|--local)
            opt_local=1;;
        -f|--force)
            opt_force=1;;
        -q|--quiet)
            (( LOGLEVEL-- ));;
        -v|--verbose)
            (( LOGLEVEL++ ));;
        -h|--help)
            help $1; exit;;
        *)
            quit "invalid option: $1";;
    esac
}

# ---- Helpers ----
function run() {
    echo "  $*"
    "$@"
}

# First non-empty line from an identity file (trim leading/trailing whitespace).
function read_identity_token() {
    local f="$1"
    [ -f "$f" ] || return 1
    local line
    while IFS= read -r line || [ -n "$line" ]; do
        line="${line#"${line%%[![:space:]]*}"}"
        line="${line%"${line##*[![:space:]]}"}"
        [ -n "$line" ] && echo "$line" && return 0
    done < "$f"
    return 1
}

# Publish VSIX to Visual Studio Marketplace and Open VSX (tokens from ~/.identity).
function publish_vsix_marketplaces() {
    local projectdir="$1"
    local pkgname="$2"
    local version="$3"
    local vsix_rel="${pkgname}-${version}.vsix"
    local vsix="${projectdir}/${vsix_rel}"
    local vs_id="${HOME}/.identity/azure-devops.id"
    local ovsx_id="${HOME}/.identity/open-vsx.id"

    [ -f "$vsix" ] || quit "VSIX not found: $vsix"

    local vs_pat ovsx_pat
    vs_pat=$(read_identity_token "$vs_id") || true
    ovsx_pat=$(read_identity_token "$ovsx_id") || true

    if [ -z "$vs_pat" ]; then
        _log1 "  Skip Visual Studio Marketplace (no token in $vs_id)"
    else
        _log1 "Publishing to Visual Studio Marketplace..."
        ( cd "$projectdir" && VSCE_PAT="$vs_pat" pnpm exec vsce publish --packagePath "$vsix_rel" ) || quit "vsce publish failed."
    fi

    if [ -z "$ovsx_pat" ]; then
        _log1 "  Skip Open VSX (no token in $ovsx_id)"
    else
        _log1 "Publishing to Open VSX..."
        ( cd "$projectdir" && OVSX_PAT="$ovsx_pat" pnpm exec ovsx publish "$vsix_rel" ) || quit "ovsx publish failed."
    fi
}

# Detect project type: debian, vsix, or nodejs
function detect_project_type() {
    local projectdir="$1"
    
    # debian: exists debian/control
    if [ -f "$projectdir/debian/control" ]; then
        echo "debian"
        return 0
    fi
    
    # vsix: jq .scripts.package package.json contains `vsce package`
    if [ -f "$projectdir/package.json" ]; then
        local package_script
        package_script=$(jq -r '.scripts.package // ""' "$projectdir/package.json" 2>/dev/null)
        if [[ "$package_script" == *"vsce package"* ]]; then
            echo "vsix"
            return 0
        fi
    fi
    
    # nodejs: exists package.json
    if [ -f "$projectdir/package.json" ]; then
        echo "nodejs"
        return 0
    fi
    
    return 1
}

# Get version by project type
function get_version() {
    local type="$1"
    local projectdir="$2"
    
    case "$type" in
        debian)
            local changelog="$projectdir/debian/changelog"
            [ -f "$changelog" ] || quit "debian/changelog not found."
            awk -F'[()]' '{print $2; exit}' "$changelog"
            ;;
        vsix|nodejs)
            local pkg_json="$projectdir/package.json"
            [ -f "$pkg_json" ] || quit "package.json not found."
            jq -r '.version // empty' "$pkg_json"
            ;;
    esac
}

# Get package name
function get_package_name() {
    local type="$1"
    local projectdir="$2"
    
    case "$type" in
        debian)
            local control="$projectdir/debian/control"
            local pkg
            if [ -f "$control" ]; then
                pkg=$(awk -F': ' '/^Source:/ {print $2; exit}' "$control")
            fi
            if [ -z "$pkg" ]; then
                basename "$projectdir"
            else
                echo "$pkg"
            fi
            ;;
        vsix|nodejs)
            jq -r '.name // empty' "$projectdir/package.json"
            ;;
    esac
}

function make_build_dir() {
    local type="$1"
    local projectdir="$2"
    case "$type" in
        debian)
            # mktemp -d "builddir-XXXXXX" --tmpdir ||
            #     quit "Could not create temporary build directory."
            echo "${projectdir%/*}"
            ;;
        vsix|nodejs)
            echo "${projectdir}"
            ;;
        *)
            echo "${projectdir}"
            ;;
    esac
}

# Build project by type
function build_project() {
    local type="$1"
    local projectdir="$2"
    local version="$3"
    local pkgname="$4"
    local outputdir="$5"
    
    case "$type" in
        debian)
            _log1 "Building debian package"
            # if [ -n "${outputdir}" ]; then
            #     dpkg_buildopts+=( --outdir="${outputdir}" )
            #     dpkg_buildopts+=( --buildinfo-option=-u${outputdir}" )
            #     dpkg_buildopts+=( --preserve-envvar=ARTIFACTS_DIR )
            # fi
            if command -v debuild &>/dev/null; then
                run debuild           "${dpkg_buildopts[@]}"
            else
                run dpkg-buildpackage "${dpkg_buildopts[@]}"
            fi
            ;;
        vsix)
            _log1 "Building vsix package"
            run pnpm package
            ;;
        nodejs)
            _log1 "Building nodejs package"
            run pnpm package
            ;;
    esac
}

# Find release attachments by type
function find_attachments() {
    local type="$1"
    local projectdir="$2"
    local version="$3"
    local pkg="$4"
    
    case "$type" in
        vsix)
            local f
            for f in "$projectdir"/${pkg}-${version}.vsix; do
                [ -f "$f" ] && echo "$f"
            done
            ;;
        nodejs)
            local f
            for f in "$projectdir"/${pkg}-${version}-dist.zip; do
                [ -f "$f" ] && echo "$f"
            done
            ;;
    esac
}

# find .deb files according to debian/control 
# A debian project can have multiple packages. 
# Find all package names appearing in Package: statements.
# Also include -dbgsym packages for binary packages.
function find_deb_files() {
    local project_dir="$1"
    local output_dir="$2"
    local version="$3"
    local pkg
    while IFS= read -r pkg; do
        if [ -n "$pkg" ]; then
            for f in "$output_dir"/${pkg}_${version}_*.deb; do
                [ -f "$f" ] && echo "$f"
            done
            for f in "$output_dir"/${pkg}-dbgsym_${version}_*.deb; do
                [ -f "$f" ] && echo "$f"
            done
        fi
    done < <(awk -F': ' '/^Package:/ {print $2}' "$project_dir/debian/control")
}

function find_artifacts_dir() {
    local dir="$1"
    while [ -n "$dir" ]; do
        if [ -d "$dir/artifacts" ]; then
            echo "$dir/artifacts"
            return 0
        fi
        local parent_dir="${dir%/*}"
        if [ "$dir" == "${parent_dir}" ]; then
            break
        fi
        dir="$parent_dir"
    done
    return 1
}

# find .changes file from the build output
function find_changes_file() {
    local project_dir="$1"
    local output_dir="$2"
    local version="$3"
    local pkg
    while IFS= read -r pkg; do
        if [ -n "$pkg" ]; then
            for f in "$output_dir"/${pkg}_${version}_*.changes; do
                [ -f "$f" ] && echo "$f"
            done
        fi
    done < <(awk -F': ' '/^Source:/ {print $2}' "$project_dir/debian/control")
}

# Get release notes
function get_release_notes() {
    local type="$1"
    local projectdir="$2"
    local version="$3"
    local pkg="$4"
    
    local notes
    notes=$(mktemp)
    
    case "$type" in
        debian)
            local changelog="$projectdir/debian/changelog"
            printf '%s\n\n' "Release ${version}" > "$notes"
            if dpkg-parsechangelog -l "$changelog" -S Changes 2>/dev/null | awk '/^  \* / { sub(/^  \* /, "- "); print }' >> "$notes"; then
                :
            else
                awk '/^  \* / { sub(/^  \* /, "- "); print } /^  -- / { exit }' "$changelog" >> "$notes"
            fi
            printf '\nSee README.md and debian/changelog.\n' >> "$notes"
            ;;
        vsix|nodejs)
            _log1 "Getting release notes from recent commit"
            printf '%s\n\n' "Release ${version}" > "$notes"
            git log -1 --format=%B >> "$notes"
            printf '\n' >> "$notes"
            ;;
    esac
    
    echo "$notes"
}

function check_prereqs() {
    local projectdir
    projectdir=$(git rev-parse --show-toplevel) || quit "Not inside a git repository."
    _log1 "Checking prerequisites..."
    _log1 "  inside git repo"
    
    local project_type
    project_type=$(detect_project_type "$projectdir")
    [ -n "$project_type" ] || quit "Could not detect project type (debian/vsix/nodejs)."
    _log1 "  📌 Project type detected: $project_type"
    
    case "$project_type" in
        debian)
            local n_tool=0
            if command -v debuild &>/dev/null; then
                _log1 "  ✅ debuild available"
                (( n_tool++ ))
            fi
            if command -v dpkg-buildpackage &>/dev/null; then
                _log1 "  ✅ dpkg-buildpackage available"
                (( n_tool++ ))
            fi
            if [ "$n_tool" -eq 0 ]; then
                quit "debuild or dpkg-buildpackage not found."
            fi
            ;;
        vsix|nodejs)
            if command -v pnpm &>/dev/null; then
                _log1 "  ✅ pnpm available"
            else
                quit "pnpm not found."
            fi
            ;;
    esac
    
    if command -v gh &>/dev/null; then
        _log1 "  ✅ gh CLI available"
    else
        quit "gh CLI not found."
    fi
    
    if gh auth status -h github.com &>/dev/null; then
        _log1 "  ✅ gh authenticated"
    else
        quit "gh not authenticated."
    fi
    
    echo "$project_type"
}

function main() {
    _log1 "Starting (LOGLEVEL=$LOGLEVEL)"
    
    local projectdir
    projectdir=$(git rev-parse --show-toplevel)
    cd "$projectdir" || quit "Could not cd to repo projectdir $projectdir."

    local project_type
    project_type=$(check_prereqs)
    _log1 "Project type: $project_type"

    local version pkgname tag
    version=$(get_version "$project_type" "$projectdir")
    [ -n "$version" ] || quit "Could not determine version."
    pkgname=$(get_package_name "$project_type" "$projectdir")
    [ -n "$pkgname" ] || pkgname=$(basename "$projectdir")
    tag="v${version}"
    _log1 "Version: $version  Package: $pkgname  Tag: $tag"

    if [ "$opt_local" == 0 ]; then
        if [[ -z $opt_force ]]; then
            if git rev-parse "$tag" &>/dev/null; then
                quit "Tag $tag already exists locally. Use -f to replace."
            fi
            if git ls-remote origin "refs/tags/$tag" 2>/dev/null | grep -q .; then
                quit "Tag $tag already exists on origin. Use -f to replace."
            fi
            if gh release view "$tag" &>/dev/null; then
                quit "Release $tag already exists. Use -f to replace."
            fi
        else
            _log1 "Force: deleting existing release and tag if present"
            gh release delete "$tag" --cleanup-tag -y 2>/dev/null || true
            git tag -d "$tag" 2>/dev/null || true
        fi
    fi

    # create tag and push
        if ! git rev-parse "$tag" &>/dev/null; then
            _log1 "Creating tag $tag"
            run git tag "$tag"
        fi
        if [[ -n $opt_force ]]; then
            run git push -f origin "$tag"
        else
            run git push origin "$tag"
        fi

    # Build the project
    if local builddir=$(make_build_dir "$project_type" "$projectdir"); then
        _log1 "📝 Build directory: $builddir"
    else
        quit "Could not create temporary build directory."
    fi

    # builddir not work, yet
    # --outdir, --buildinfo-option=-u... not working.
    if ! build_project "$project_type" "$projectdir" "$version" "$pkgname"; then
        quit "Build failed."
        return 1
    fi

    if [ "$project_type" == "vsix" ] && [ "$opt_local" == 0 ]; then
        publish_vsix_marketplaces "$projectdir" "$pkgname" "$version"
    fi

    if [ "$project_type" == "debian" ]; then
      # find .deb files and install
        local debdir="$builddir"
        local deb_files=()
        while IFS= read -r deb; do
            [ -n "$deb" ] && deb_files+=( "$deb" )
        done < <(find_deb_files "$projectdir" "$debdir" "$version" )
        [ ${#deb_files[@]} -gt 0 ] || quit "No .deb files found."
        _log1 "Debian files: ${deb_files[*]}"

        # find artifacts/ dir in parents and copy builddir/* to it
        # local artifacts_dir=$(find_artifacts_dir "$projectdir") ||
        #     quit "Could not find artifacts directory."
        # _log1 "Copying builddir/* to artifacts directory: $artifacts_dir"
        # run cp -r "$builddir"/* "$artifacts_dir/"

        # install .deb packages, dput changes
        sudo dpkg -i "${deb_files[@]}"

      # find .changes file and dput
        local changes_file=$(find_changes_file "$projectdir" "$debdir" "$version")
        [ -n "$changes_file" ] || quit "No .changes file found."
        _log1 "Changes file: $changes_file"

        # sign the deb and put the changes file to the remote repository
        # for deb in "${deb_files[@]}"; do
        #     dpkg-sig -k Lenik -s builder "${deb}"
        # done

        if [ "$opt_local" == 0 ]; then
            dput -f bodz "${changes_file}"
        fi
    fi

    if [ "$opt_local" == 1 ]; then
        return 0
    fi

    # Find attachments
        local attachments=( "${deb_files[@]}" )
        local att
        while IFS= read -r att; do
            [ -n "$att" ] && attachments+=( "$att" )
        done < <(find_attachments "$project_type" "$projectdir" "$version" "$pkgname")
        [ ${#attachments[@]} -gt 0 ] || quit "No build artifacts produced."
        _log1 "Attachments: ${attachments[*]}"

    # create source tarball
        local tarball
        _log1 "Creating source tarball preserving original sources"
        tarball="${pkgname}-${version}.tar.gz"
        run git archive --format=tar.gz --prefix="${pkgname}-${version}/" -o "$tarball" HEAD

    # Get release notes
        local notes
        notes=$(get_release_notes "$project_type" "$projectdir" "$version" "$pkgname")
        trap 'rm -f "$notes"' EXIT

        _log1 "Creating GitHub release $tag"
        run gh release create "$tag" "$tarball" "${attachments[@]}" --title "$tag" --notes-file "$notes"

        echo "Created release $tag"
}

boot "$@"
